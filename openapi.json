  "info": {
    "description": "Public HTTP API for IntoTheOpen post evaluation and similarity retrieval.\n\n## Versioning\n\nAll stable integration endpoints live under **`/api/v1/`**. See\n`docs/api/VERSIONING.md` for deprecation and backward-compatibility rules.\n\n## Errors\n\nAll non-validation failures return `ApiErrorResponse` (`code`, `message`,\n`retryable`, `details`). Request validation failures return HTTP 422 as\n`ValidationErrorResponse`. See `docs/api/API_CONTRACT.md` for frontend handling.",
    "title": "IntoTheOpen API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/evaluate": {
      "post": {
        "description": "Run the async evaluation cycle end-to-end over HTTP.",
        "operationId": "evaluate_api_v1_evaluate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "example": {
                "content": "Excited to announce our new backend engineering hire!",
                "reembed_variant_neighbors": false,
                "use_voice_profile": true,
                "user_id": "user-42",
                "variant_strategy": "dimension"
              },
              "schema": {
                "$ref": "#/components/schemas/EvaluateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "diagnostics": {
                    "clarity": {
                      "advantages": [
                        "Single clear announcement"
                      ],
                      "flaws": [],
                      "improvements": [
                        "Optional one-line benefit for the reader"
                      ],
                      "score": 8.0
                    },
                    "seo": {
                      "advantages": [
                        "Clear role signal"
                      ],
                      "flaws": [
                        "Missing industry keywords in the first line"
                      ],
                      "improvements": [
                        "Add stack or team context in the hook"
                      ],
                      "score": 7.5
                    },
                    "tone": {
                      "advantages": [
                        "Professional and approachable"
                      ],
                      "flaws": [
                        "Slightly generic enthusiasm"
                      ],
                      "improvements": [
                        "Name the team or mission tie-in"
                      ],
                      "score": 7.0
