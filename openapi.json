{
  "components": {
    "schemas": {
      "ApiErrorResponse": {
        "description": "Documented error envelope for frontend handling.",
        "properties": {
          "code": {
            "description": "Machine-readable error code (e.g. EMBED_FAILED, AGENT_UNAVAILABLE).",
            "title": "Code",
            "type": "string"
          },
          "details": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional structured context (field names, provider hint, etc.).",
            "title": "Details"
          },
          "message": {
            "description": "Human-readable summary safe to show in the UI.",
            "title": "Message",
            "type": "string"
          },
          "retryable": {
            "description": "Whether the client should offer a retry action.",
            "title": "Retryable",
            "type": "boolean"
          }
        },
        "required": [
          "code",
          "message",
          "retryable"
        ],
        "title": "ApiErrorResponse",
        "type": "object"
      },
      "DiagnosticResult": {
        "description": "Single diagnostic worker output (T3.3 contract).",
        "properties": {
          "advantages": {
            "items": {
              "type": "string"
            },
            "title": "Advantages",
            "type": "array"
          },
          "flaws": {
            "items": {
              "type": "string"
            },
            "title": "Flaws",
            "type": "array"
          },
          "improvements": {
            "items": {
              "type": "string"
            },
            "title": "Improvements",
            "type": "array"
          },
          "score": {
            "maximum": 10.0,
            "minimum": 0.0,
            "title": "Score",
            "type": "number"
          }
        },
        "required": [
          "score"
        ],
        "title": "DiagnosticResult",
        "type": "object"
      },
      "EvaluateRequest": {
        "properties": {
          "content": {
            "description": "Draft post text to evaluate",
            "minLength": 1,
            "title": "Content",
            "type": "string"
          },
          "reembed_variant_neighbors": {
            "default": false,
            "description": "If true, each of the 3 variants re-embeds its own text and fetches its own nearest historical neighbors before being scored (more accurate when a variant shifts topic/angle, at the cost of up to 3 extra Gemini embed calls + DB queries). If false (default), all variants are scored against the original draft's shared neighbors (cheaper, and keeps all 3 compared against one consistent baseline).",
            "title": "Reembed Variant Neighbors",
            "type": "boolean"
          },
          "seo_mode": {
            "anyOf": [
              {
                "enum": [
                  "corpus",
                  "gemini_only"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "SEO/discoverability diagnostic mode. 'corpus' (default) grounds the SEO worker in your scraped dataset; 'gemini_only' uses the legacy static prompt for A/B testing.",
            "title": "Seo Mode"
          },
          "use_google_trends": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "description": "Tier 2: include Google Trends timeliness signals (web-wide, not LinkedIn-specific). Defaults to settings.google_trends_enabled (off unless enabled in env); always off in gemini_only.",
            "title": "Use Google Trends"
          },
          "use_voice_profile": {
            "default": true,
            "description": "Whether to derive and apply the subscriber's voice profile when user_id is given. Has no effect if user_id is not set. Set to false to scope retrieval to the subscriber without personalizing the agent prompts.",
            "title": "Use Voice Profile",
            "type": "boolean"
          },
          "user_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional subscriber id (personalization). When given: (1) similar-post retrieval is scoped to that subscriber's own posts, falling back to the global corpus if they don't have enough yet, and (2) a derived voice profile from their top posts is injected into every agent's prompt, when enough of their own posts exist.",
            "title": "User Id"
          },
          "variant_strategy": {
            "default": "dimension",
            "description": "Which distinctness axis the T3.4 Variant Optimisation Engine should use: 'dimension' (one variant per SEO/clarity/tone diagnostic), 'narrative' (different hook/story angles), or 'tiered' (safe/moderate/bold rewrite).",
            "enum": [
              "dimension",
              "narrative",
              "tiered"
            ],
            "title": "Variant Strategy",
            "type": "string"
          }
        },
        "required": [
          "content"
        ],
        "title": "EvaluateRequest",
        "type": "object"
      },
      "EvaluateResponse": {
        "description": "Stable v1 response contract for POST /api/v1/evaluate.",
        "properties": {
          "diagnostics": {
            "additionalProperties": {
              "$ref": "#/components/schemas/DiagnosticResult"
            },
            "description": "Diagnostic worker outputs keyed by check name (e.g. seo, clarity, tone).",
            "title": "Diagnostics",
            "type": "object"
          },
          "draft_content": {
            "title": "Draft Content",
            "type": "string"
          },
          "embedding_model_version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Embedding Model Version"
          },
          "errors": {
            "description": "Non-fatal agent failures collected during the evaluation cycle.",
            "items": {
              "type": "string"
            },
            "title": "Errors",
            "type": "array"
          },
          "predictor_result": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PredictorResult"
              },
              {
                "type": "null"
              }
            ]
          },
          "query_embedding": {
            "anyOf": [
              {
                "items": {
                  "type": "number"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Query Embedding"
          },
          "run_metadata": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/RunMetadata"
              },
              {
                "type": "null"
              }
            ]
          },
          "similar_posts": {
            "items": {
              "$ref": "#/components/schemas/SimilarPost"
            },
            "title": "Similar Posts",
            "type": "array"
          },
          "variants": {
            "items": {
              "$ref": "#/components/schemas/VariantResult"
            },
            "title": "Variants",
            "type": "array"
          },
          "voice_profile": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/VoiceProfile"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "draft_content"
        ],
        "title": "EvaluateResponse",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "api_version": {
