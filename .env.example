APIFY_API_TOKEN=your_apify_api_token_here
APIFY_ACTOR_ID=your_linkedin_actor_id_here

# curious_coder/linkedin-profile-scraper - enriches post authors with
# follower count / industry / company data. Requires an authenticated
# LinkedIn session, see LINKEDIN_COOKIES below.
APIFY_PROFILE_ACTOR_ID=your_profile_actor_id_here

# JSON array of cookie objects exported via the Cookie-Editor browser
# extension while logged into LinkedIn. SENSITIVE: treat like a password,
# never commit a real value, rotate if it's ever exposed.
LINKEDIN_COOKIES=

# Gemini API key for the post analysis pipeline (Step 2).
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

RAW_DATA_DIR=data/raw
DEFAULT_SEARCH_LIMIT=20

# Postgres + pgvector (T1.4/T1.5). docker-compose.yml reads the POSTGRES_*
# vars to initialise the container; the app reads DATABASE_URL to connect.
# DB_DATA_PATH is where Postgres data is bind-mounted on the host - locally
# this is a plain folder; on the real EC2 deployment point it at the
# mounted EBS volume path instead (see T1.4_DATABASE_PLAN.md).
POSTGRES_USER=ito
POSTGRES_PASSWORD=change_me_before_use
POSTGRES_DB=ito_posts
DB_DATA_PATH=./data/pgdata
DATABASE_URL=postgresql://ito:change_me_before_use@localhost:5432/ito_posts
