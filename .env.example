APIFY_API_TOKEN=your_apify_api_token_here
APIFY_ACTOR_ID=your_linkedin_actor_id_here

# harvestapi/linkedin-profile-scraper - enriches PERSONAL-profile post
# authors with follower count / connections / headline data (no cookies or
# LinkedIn login needed). Only called for personal authors - business/
# company page authors' follower counts come free from the post scraper's
# own data (see processors/profile_enricher.py).
APIFY_PROFILE_ACTOR_ID=harvestapi/linkedin-profile-scraper

# JSON array of cookie objects exported via the Cookie-Editor browser
# extension while logged into LinkedIn. SENSITIVE: treat like a password,
# never commit a real value, rotate if it's ever exposed.
LINKEDIN_COOKIES=

# Gemini API key for the post analysis pipeline (Step 2).
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: model for Evaluation Cycle agents (pydantic-ai). Defaults to
# gemini-2.5-flash; post_analyser uses GEMINI_MODEL in config/settings.py.
# AGENT_GEMINI_MODEL=gemini-2.5-flash-lite

RAW_DATA_DIR=data/raw
DEFAULT_SEARCH_LIMIT=20

# Postgres + pgvector (T1.4/T1.5). docker-compose.yml reads the POSTGRES_*
# vars to initialise the container; the app reads DATABASE_URL to connect.
# DB_DATA_PATH is where Postgres data is bind-mounted on the host - locally
# this is a plain folder; on the real EC2 deployment point it at the
# mounted EBS volume path instead (see T1.4_DATABASE_PLAN.md).
POSTGRES_USER=ito
POSTGRES_PASSWORD=change_me_before_use
POSTGRES_DB=ito_posts
DB_DATA_PATH=./data/pgdata
# DATABASE_URL is used by host-side scripts (points at localhost). Inside the
# Docker Compose stack, the `api`/`migrate` services override this to reach
# Postgres over the compose network (host `db`), so this localhost value does
# NOT need to change for `docker compose up`.
DATABASE_URL=postgresql://ito:change_me_before_use@localhost:5432/ito_posts

# T6.6: re-scrape cached author profiles after this many days (default 30).
PROFILE_CACHE_STALENESS_DAYS=30

# Prediction validation pipeline — auto-scrape, predict, validate after window.
VALIDATION_WINDOW_HOURS=48
# Optional dev override (minutes). When set, replaces VALIDATION_WINDOW_HOURS.
# VALIDATION_DEV_WINDOW_MINUTES=5
VALIDATION_MAX_POSTS_PER_RUN=20
VALIDATION_MIN_POST_AGE_HOURS=0
VALIDATION_DATA_DIR=data/validation

# Tier 1 discoverability (T6 Point 2): corpus = ground SEO in your scraped
# dataset (default); gemini_only = legacy static prompt for A/B testing.
SEO_DISCOVERABILITY_MODE=corpus
CORPUS_BENCHMARK_TTL_HOURS=24

# Tier 2 discoverability: Google Trends via pytrends (web-wide timeliness only).
# Off by default — set true to include web-wide timeliness hints in corpus SEO mode.
GOOGLE_TRENDS_ENABLED=false
GOOGLE_TRENDS_CACHE_TTL_HOURS=12
# Optional geo filter for Trends (empty = global). Example: US
GOOGLE_TRENDS_GEO=

# ── Telemetry (Docker Compose monolith stack) ─────────────────────────────
# Grafana admin login, reachable at http://<host>:3000. Change before any
# non-local use — these are the initial superuser credentials.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_before_use

# ── Langfuse self-hosted trace engine ─────────────────────────────────────
# Self-hosted LLM tracing UI at http://localhost:3001 (started by docker
# compose). Set this pair to any pk-lf-... / sk-lf-... values to turn tracing
# on; leave blank to disable it (silent no-op). The backing stores use local
# defaults from docker-compose.yml — override those there for non-local use.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Host port overrides (optional) ────────────────────────────────────────
# The compose stack publishes these ports on the host. Override them only if
# a port is already taken on the machine (the containers always talk to each
# other over the internal network regardless of these host mappings).
# DB_HOST_PORT=5432
# API_HOST_PORT=8000
# GRAFANA_HOST_PORT=3000
# LANGFUSE_HOST_PORT=3001
