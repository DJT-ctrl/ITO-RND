# Reference only — NOT wired up or tested (no EC2 instance exists yet).
#
# This mirrors the same deployment blocker documented in T1.4_DATABASE_PLAN.md
# for Phase 2 (EC2 + EBS). Once an EC2 instance exists, this config forwards
# web traffic to the Uvicorn process serving api.main:app on port 8000
# (T2.1's "Configure Nginx on the EC2 instance to forward web traffic to
# Uvicorn").
#
# Example usage once deployed:
#   sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/ito-api
#   sudo ln -s /etc/nginx/sites-available/ito-api /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name _;  # replace with the EC2 instance's public IP or domain

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
