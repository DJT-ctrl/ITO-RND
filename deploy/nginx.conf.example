# SUPERSEDED — this bare reference has been replaced by the real, tested edge
# layer in deploy/edge/. It is kept only as a minimal illustration.
#
# For the production setup — Cloudflare free proxy + Nginx with automated HTTPS
# (Let's Encrypt DNS-01), origin lockdown to Cloudflare IPs, real client-IP
# restoration, rate limiting, security headers, and a self-contained test
# suite — use deploy/edge/ instead:
#
#     deploy/edge/README.md              full runbook + security model
#     deploy/edge/nginx/                 the real Nginx config
#     deploy/edge/cloudflare/            Cloudflare API setup + IP updater
#     deploy/edge/certbot/               automated HTTPS (Let's Encrypt DNS-01)
#     deploy/edge/docker-compose.edge.yml   nginx + certbot overlay
#     deploy/edge/tests/run-all.sh       verify it all (Docker + mock CF API)
#
# Minimal illustrative config (NOT hardened — see deploy/edge/ for the real one):

server {
    listen 80;
    server_name _;  # replace with the domain; the edge/ config redirects to HTTPS

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
